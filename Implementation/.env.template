# Environment Variables Template
# Copy this file to .env and fill in your actual API keys

# Mistral AI API Key (required for LLM functionality)
MISTRAL_API_KEY=your_mistral_api_key_here

# Wazuh API Key (if using Wazuh integration)
WAZUH_API_KEY=your_wazuh_api_key_here

# VirusTotal API Key (for IP/file reputation checks)
VT_API_KEY=your_virustotal_api_key_here

# AbuseIPDB API Key (for IP reputation checks)
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# IDS: auto-queue SOC workflow on /predict/ when confidence is above this (0–1). Default 0.90 (= >90%).
# IDS_AUTO_WORKFLOW_CONFIDENCE=0.90
# Optional: stricter auto-pilot for remediation only (defaults to IDS_AUTO_WORKFLOW_CONFIDENCE if unset).
# IDS_REMEDIATION_AUTO_MIN_CONFIDENCE=0.90

# --- API Auth (required) ----------------------------------------------------
# Read-scope key. Must NOT equal the default "ids-secret-key" unless
# IDS_ALLOW_DEFAULT_KEY=true (local dev only). Rotate for prod.
IDS_API_KEY=change_me_read_scope
# Admin-scope key. Guards /soc/auto-rules, /sandbox/clear, /workflow/process.
IDS_ADMIN_API_KEY=change_me_admin_scope
# Escape hatch for local dev — DO NOT enable in production.
# IDS_ALLOW_DEFAULT_KEY=false

# --- LLM provider -----------------------------------------------------------
# ragarenn | ollama | mistral | openai | anthropic
LLM_PROVIDER=ollama
# Optional overrides
# LLM_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434
# RAGARENN_API_BASE=https://ragarenn.eskemm-numerique.fr/sso/ch@t/api
# MISTRAL_API_BASE=https://api.mistral.ai/v1

# --- Reputation feed --------------------------------------------------------
# simulated | abuseipdb | null
REPUTATION_SOURCE=simulated

# --- Rate limits (slowapi rate syntax: "N/period") --------------------------
# IDS_RATE_LIMIT_PREDICT=60/minute
# IDS_RATE_LIMIT_AUTO_RULES=10/minute
# IDS_RATE_LIMIT_SANDBOX_CLEAR=3/minute

# --- Block-list expiry sweep -----------------------------------------------
# IDS_BLOCKLIST_SWEEP_SEC=60

# --- Self-IP allowlist -----------------------------------------------------
# Flows whose SOURCE IP is one of these are never flagged: inference is
# skipped, no SOC workflow is spawned, the dashboard still shows the flow
# tagged self_origin=true for visibility. Useful when running nmap / burp /
# other offensive tooling from the same host as the IDS. Local interface
# addresses are auto-detected every IDS_SELF_IPS_REFRESH_SEC seconds.
# IDS_SELF_IPS=10.0.0.5,192.168.1.10
# IDS_AUTODETECT_SELF_IPS=true
# IDS_SELF_IPS_REFRESH_SEC=60

# --- SSE stream -------------------------------------------------------------
# IDS_SSE_INTERVAL_SEC=2

# --- Drift window -----------------------------------------------------------
# IDS_DRIFT_WINDOW=500

# --- LLM performance --------------------------------------------------------
# Response cache (hash of model+messages+temp -> reply). Only caches when
# temperature <= 0.3 so non-determinism is preserved. Set a dir to persist
# across restarts.
# IDS_LLM_CACHE=true
# IDS_LLM_CACHE_SIZE=512
# IDS_LLM_CACHE_TTL_SEC=3600
# IDS_LLM_CACHE_DIR=.cache/llm
#
# Prompt compression (collapses verbose JSON dumps before sending to the LLM)
# IDS_LLM_COMPRESS=true
# IDS_LLM_MAX_JSON_CHARS=800
# IDS_LLM_MAX_PROMPT_CHARS=6000
#
# Ollama keep-alive warmer (pings model every 120s so it stays resident)
# IDS_LLM_WARMER=true
#
# Parallel Red/Blue in the War Room (run concurrently then synthesise)
# IDS_WARROOM_PARALLEL=true
#
# Per-role model overrides (fastest triage, richer synthesis)
# IDS_TIER1_MODEL=llama3.2:1b
# IDS_TIER2_MODEL=llama3.2
# IDS_TIER3_MODEL=llama3.2
# IDS_REDTEAM_MODEL=llama3.2
# IDS_BLUETEAM_MODEL=llama3.2
# IDS_PURPLETEAM_MODEL=llama3.2

# Instructions:
# 1. Copy this file: cp .env.template .env
# 2. Replace the placeholder values with your actual API keys
# 3. Never commit the .env file to version control

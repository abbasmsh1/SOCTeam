# Environment Variables Template
# Copy this file to .env and fill in your actual API keys

# Mistral AI API Key (required for LLM functionality)
MISTRAL_API_KEY=your_mistral_api_key_here

# Wazuh API Key (if using Wazuh integration)
WAZUH_API_KEY=your_wazuh_api_key_here

# VirusTotal API Key (for IP/file reputation checks)
VT_API_KEY=your_virustotal_api_key_here

# AbuseIPDB API Key (for IP reputation checks)
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# IDS: auto-queue SOC workflow on /predict/ when confidence is above this (0–1). Default 0.5 (= >50%).
# IDS_AUTO_WORKFLOW_CONFIDENCE=0.5
# Optional: stricter auto-pilot for remediation only (defaults to IDS_AUTO_WORKFLOW_CONFIDENCE if unset).
# IDS_REMEDIATION_AUTO_MIN_CONFIDENCE=0.5

# Instructions:
# 1. Copy this file: cp .env.template .env
# 2. Replace the placeholder values with your actual API keys
# 3. Never commit the .env file to version control

VITE_IDS_BASE_URL=http://localhost:6050
# Read-scope key (GET endpoints, dashboard polling).
VITE_IDS_API_KEY=ids-secret-key
# Admin-scope key — required for POST /soc/auto-rules, /sandbox/clear,
# /quarantine/{ip}/allow|deny, /blocked-ips DELETE, /start|stop-live-capture,
# /self-ips/refresh, /rl/train, /rl/feedback, /workflow/process.
# When this is set the frontend sends it on every request (admin is a superset
# of read-scope on the server). Leave blank to operate in read-only mode.
VITE_IDS_ADMIN_API_KEY=ids-admin-key
